<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🧟 僵尸生存战</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: #000;
    overflow: hidden;
    cursor: crosshair;
    font-family: 'Arial', sans-serif;
  }
  canvas { display: block; }
  
  /* 暂停按钮 */
  #pauseBtn {
    position: fixed;
    top: 15px;
    right: 250px;
    padding: 8px 16px;
    background: rgba(192, 57, 43, 0.8);
    color: #fff;
    border: 1px solid #e74c3c;
    border-radius: 4px;
    cursor: pointer;
    z-index: 100;
    font-weight: bold;
    transition: all 0.3s;
    pointer-events: auto;
  }
  #pauseBtn:hover {
    background: rgba(192, 57, 43, 1);
    transform: scale(1.05);
  }
  
  /* 暂停界面 */
  #pauseMenu {
    position: fixed;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.85);
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    z-index: 150;
  }
  #pauseMenu.active {
    display: flex;
  }
  .pause-content {
    text-align: center;
  }
  .pause-content h2 {
    color: #e74c3c;
    font-size: 48px;
    margin-bottom: 30px;
    text-shadow: 0 0 20px rgba(231,76,60,0.6);
  }
  .pause-stats {
    color: #aaa;
    margin: 20px 0;
    font-size: 16px;
    line-height: 2;
  }
  .pause-stats span {
    color: #fff;
    font-weight: bold;
  }
  
  /* 商城 */
  #shopMenu {
    position: fixed;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.9);
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    z-index: 150;
  }
  #shopMenu.active {
    display: flex;
  }
  .shop-content {
    text-align: center;
    max-height: 90vh;
    overflow-y: auto;
  }
  .shop-content h2 {
    color: #f39c12;
    font-size: 48px;
    margin-bottom: 20px;
    text-shadow: 0 0 20px rgba(243,156,18,0.6);
  }
  .shop-balance {
    color: #ffd700;
    font-size: 24px;
    font-weight: bold;
    margin-bottom: 30px;
  }
  .shop-items {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 30px;
  }
  .shop-item {
    background: linear-gradient(135deg, #2c3e50, #34495e);
    border: 2px solid #e74c3c;
    padding: 15px;
    border-radius: 8px;
    color: #fff;
    cursor: pointer;
    transition: all 0.3s;
  }
  .shop-item:hover:not(.purchased):not(.owned) {
    background: linear-gradient(135deg, #34495e, #3d5a73);
    transform: scale(1.05);
    box-shadow: 0 0 15px rgba(231,76,60,0.5);
  }
  .shop-item.owned {
    opacity: 0.5;
    border-color: #2ecc71;
  }
  .shop-item-name {
    font-weight: bold;
    font-size: 16px;
  }
  .shop-item-stats {
    font-size: 12px;
    color: #aaa;
    margin: 8px 0;
  }
  .shop-item-cost {
    color: #ffd700;
    font-weight: bold;
    font-size: 14px;
  }

  /* ===== 开始界面 ===== */
  .overlay {
    position: fixed; top: 0; left: 0;
    width: 100%; height: 100%;
    display: flex; flex-direction: column;
    justify-content: center; align-items: center;
    z-index: 100;
    background: radial-gradient(ellipse at center, #1a0a0a 0%, #000 80%);
  }
  .overlay.hidden { display: none; }

  .title {
    font-size: 72px;
    color: #c0392b;
    text-shadow: 0 0 30px rgba(192,57,43,0.8), 0 4px 8px rgba(0,0,0,0.9);
    margin-bottom: 10px;
    letter-spacing: 6px;
    animation: pulse 2s infinite;
  }
  .subtitle {
    color: #888;
    font-size: 18px;
    margin-bottom: 40px;
    letter-spacing: 3px;
  }
  @keyframes pulse {
    0%,100% { transform: scale(1); }
    50% { transform: scale(1.03); }
  }

  .btn {
    background: linear-gradient(145deg, #c0392b, #8e2218);
    color: #fff;
    border: 2px solid #e74c3c;
    padding: 16px 50px;
    font-size: 22px;
    border-radius: 8px;
    cursor: pointer;
    letter-spacing: 3px;
    transition: all 0.3s;
    text-transform: uppercase;
    margin: 8px;
  }
  .btn:hover {
    background: linear-gradient(145deg, #e74c3c, #c0392b);
    transform: scale(1.08);
    box-shadow: 0 0 30px rgba(231,76,60,0.6);
  }

  .controls-info {
    margin-top: 40px;
    color: #666;
    font-size: 14px;
    text-align: center;
    line-height: 2;
  }
  .controls-info span { color: #e74c3c; font-weight: bold; }

  .game-over-score {
    font-size: 28px;
    color: #e74c3c;
    margin: 15px 0 30px;
  }
  .stats-row {
    display: flex;
    gap: 40px;
    margin-bottom: 20px;
  }
  .stat-item {
    text-align: center;
    color: #aaa;
  }
  .stat-item .num {
    font-size: 36px;
    color: #fff;
    display: block;
    text-shadow: 0 0 10px rgba(231,76,60,0.5);
  }

  /* ===== HUD ===== */
  #hud {
    position: fixed;
    top: 0; left: 0; right: 0;
    padding: 15px 25px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 50;
    background: linear-gradient(180deg, rgba(0,0,0,0.7) 0%, transparent 100%);
    pointer-events: none;
  }
  .hud-left, .hud-center, .hud-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .hud-item {
    text-align: center;
  }
  .hud-item .label {
    font-size: 10px;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .hud-item .val {
    font-size: 24px;
    color: #fff;
    font-weight: bold;
  }
  .health-bar-bg {
    width: 200px;
    height: 12px;
    background: #333;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid #555;
  }
  .health-bar {
    height: 100%;
    background: linear-gradient(90deg, #e74c3c, #2ecc71);
    border-radius: 6px;
    transition: width 0.3s;
  }
  .ammo-display {
    font-size: 22px;
    color: #f39c12;
    font-weight: bold;
  }
  /* 获得成就动画 */
  .achievement {
    position: fixed;
    top: 30px;
    right: 30px;
    background: linear-gradient(135deg, #e74c3c, #c0392b);
    color: #fff;
    padding: 15px 25px;
    border-radius: 8px;
    border: 2px solid #f39c12;
    box-shadow: 0 0 20px rgba(231,76,60,0.6);
    z-index: 99;
    animation: slideIn 0.5s ease-out, slideOut 0.5s ease-out 3.5s forwards;
    pointer-events: none;
  }
  .achievement-title {
    font-weight: bold;
    font-size: 14px;
  }
  .achievement-desc {
    font-size: 12px;
    opacity: 0.9;
  }
  @keyframes slideIn {
    from { transform: translateX(400px); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }
  @keyframes slideOut {
    from { transform: translateX(0); opacity: 1; }
    to { transform: translateX(400px); opacity: 0; }
  }
  /* 杀戮链特效 */
  .killstreak {
    position: fixed;
    bottom: 100px;
    left: 50%;
    transform: translateX(-50%);
    color: #f39c12;
    font-size: 36px;
    font-weight: bold;
    text-shadow: 0 0 20px rgba(243,156,18,0.8);
    z-index: 70;
    opacity: 0;
    pointer-events: none;
  }
  .killstreak.active {
    animation: killstreakPulse 0.6s ease-out forwards;
  }
  @keyframes killstreakPulse {
    0% { transform: translateX(-50%) scale(0.5); opacity: 1; }
    100% { transform: translateX(-50%) scale(1); opacity: 0; }
  }
  .wave-announce {
    position: fixed;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 60px;
    color: #e74c3c;
    text-shadow: 0 0 40px rgba(231,76,60,0.8);
    z-index: 60;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.5s;
    letter-spacing: 5px;
  }
  .wave-announce.show {
    opacity: 1;
    animation: waveIn 2s ease-out forwards;
  }
  @keyframes waveIn {
    0% { transform: translate(-50%,-50%) scale(2); opacity: 0; }
    20% { transform: translate(-50%,-50%) scale(1); opacity: 1; }
    80% { opacity: 1; }
    100% { opacity: 0; transform: translate(-50%,-50%) scale(0.8); }
  }
</style>
</head>
<body>

<canvas id="game"></canvas>

<!-- HUD -->
<div id="hud" class="hidden">
  <div class="hud-left">
    <div class="hud-item">
      <div class="label">生命值</div>
      <div class="health-bar-bg"><div class="health-bar" id="healthBar"></div></div>
    </div>
    <div class="hud-item" style="margin-left: 30px;">
      <div class="label">武器</div>
      <div class="val" id="hudWeapon">🔫</div>
    </div>
  </div>
  <div class="hud-center">
    <div class="hud-item">
      <div class="label">波次</div>
      <div class="val" id="hudWave">1</div>
    </div>
  </div>
  <div class="hud-right">
    <div class="hud-item">
      <div class="label">击杀</div>
      <div class="val" id="hudKills">0</div>
    </div>
    <div class="hud-item">
      <div class="label">得分</div>
      <div class="val" id="hudScore">0</div>
    </div>
    <div class="hud-item">
      <div class="label">金币</div>
      <div class="val" id="hudCoins">0</div>
    </div>
    <div class="hud-item">
      <div class="ammo-display">🔫 <span id="hudAmmo">30</span></div>
      <div class="label">弹药 (R重装)</div>
    </div>
  </div>
</div>

<!-- 波次公告 -->
<div class="wave-announce" id="waveAnnounce"></div>

<!-- 杀戮链特效 -->
<div class="killstreak" id="killstreakHUD"></div>

<!-- 暂停按钮 -->
<button id="pauseBtn" style="display:none;" onclick="togglePause()">暂停 (P)</button>
<button id="shopBtn" style="display:none; position: fixed; top: 15px; right: 120px; padding: 8px 16px; background: rgba(243, 156, 18, 0.8); color: #fff; border: 1px solid #f39c12; border-radius: 4px; cursor: pointer; z-index: 100; font-weight: bold; pointer-events: auto; transition: all 0.3s;" onclick="toggleShop()">商城 (B)</button>

<!-- 暂停菜单 -->
<div id="pauseMenu">
  <div class="pause-content">
    <h2>⏸ 游戏暂停</h2>
    <div class="pause-stats">
      <div>当前得分: <span id="pauseScore">0</span></div>
      <div>击杀数: <span id="pauseKills">0</span></div>
      <div>波次: <span id="pauseWave">1</span></div>
    </div>
    <button class="btn" onclick="togglePause()" style="margin-top: 30px;">继续游戏 (P)</button>
  </div>
</div>

<!-- 商城系统 -->
<div id="shopMenu">
  <div class="shop-content">
    <h2>💰 武器商城</h2>
    <div class="shop-balance">金币: <span id="shopCoins">0</span></div>
    <div id="shopItems" class="shop-items"></div>
    <button class="btn" onclick="toggleShop()" style="margin-top: 20px;">关闭 (B)</button>
  </div>
</div>

<!-- 开始界面 -->
<div class="overlay" id="startScreen">
  <div class="title">🧟 僵尸围城</div>
  <div class="subtitle">ZOMBIE SURVIVAL</div>
  <button class="btn" onclick="startGame()">开始战斗</button>
  <div class="controls-info">
    <span>W A S D</span> 移动 &nbsp;|&nbsp;
    <span>鼠标</span> 瞄准 &nbsp;|&nbsp;
    <span>左键</span> 射击<br>
    <span>R</span> 换弹 &nbsp;|&nbsp;
    <span>空格</span> 翻滚闪避 &nbsp;|&nbsp;
    消灭所有僵尸，活下去！
  </div>
</div>

<!-- 游戏结束 -->
<div class="overlay hidden" id="gameOverScreen">
  <div class="title">☠️ 你阵亡了</div>
  <div class="game-over-score" id="goScore">得分: 0</div>
  <div class="stats-row">
    <div class="stat-item"><span class="num" id="goKills">0</span>击杀数</div>
    <div class="stat-item"><span class="num" id="goWave">1</span>到达波次</div>
    <div class="stat-item"><span class="num" id="goAccuracy">0%</span>命中率</div>
  </div>
  <button class="btn" onclick="startGame()">再来一局</button>
</div>

<script>
// ===================== 初始化 =====================
const canvas = document.getElementById('game');
const ctx = canvas.getContext('2d');
let W, H;

function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

// ===================== 游戏变量 =====================
let player, zombies, bullets, particles, pickups, bloodSplats, floatingTexts;
let score, kills, wave, zombiesLeft, waveDelay;
let shotsFired, shotsHit;
let gameRunning = false;
let gamePaused = false;
let keys = {};
let mouse = { x: W/2, y: H/2, down: false };
let camera = { x: 0, y: 0 };
let lastTime = 0;
let shootCooldown = 0;
let dashCooldown = 0;
let reloading = false;
let reloadTimer = 0;
let killstreakCounter = 0;
let lastKillTime = 0;
let audioContext = null;
let coins = 0;
let shopOpen = false;

const MAP_W = 2400;
const MAP_H = 1800;

// ===================== 武器系统 =====================
const WEAPONS = {
  pistol: { name: '手枪', damage: 1, fireRate: 0.12, ammo: 30, ammoPerShot: 1, spread: 0.08, cost: 0, owned: true, emoji: '🔫' },
  ak47: { name: 'AK-47', damage: 2, fireRate: 0.08, ammo: 30, ammoPerShot: 1, spread: 0.12, cost: 500, owned: false, emoji: '🔫' },
  m4: { name: 'M4卡宾枪', damage: 1.5, fireRate: 0.06, ammo: 40, ammoPerShot: 1, spread: 0.06, cost: 800, owned: false, emoji: '🔫' },
  shotgun: { name: '霰弹枪', damage: 5, fireRate: 0.5, ammo: 8, ammoPerShot: 2, spread: 0.3, cost: 600, owned: false, emoji: '🔫' },
  grenade: { name: '手雷', damage: 20, fireRate: 2, ammo: 5, ammoPerShot: 1, spread: 0, cost: 400, owned: false, emoji: '💣' },
  knife: { name: '匕首', damage: 3, fireRate: 0.3, ammo: 999, ammoPerShot: 0, spread: 0, cost: 200, owned: false, emoji: '🔪' },
};

// ===================== 玩家类 =====================
function createPlayer() {
  return {
    x: MAP_W / 2,
    y: MAP_H / 2,
    radius: 18,
    speed: 220,
    hp: 100,
    maxHp: 100,
    angle: 0,
    currentWeapon: 'pistol',
    weapons: { pistol: { ammo: 30, maxAmmo: 30 }, ak47: { ammo: 30, maxAmmo: 30 }, m4: { ammo: 40, maxAmmo: 40 }, shotgun: { ammo: 8, maxAmmo: 8 }, grenade: { ammo: 5, maxAmmo: 5 }, knife: { ammo: 999, maxAmmo: 999 } },
    invincible: 0,
    dashTimer: 0,
    dashDx: 0,
    dashDy: 0,
    attackPower: 1.0,
    armor: 0,
    attackSpeed: 1.0,
  };
}

// ===================== 僵尸类型 =====================
const ZOMBIE_TYPES = {
  normal: {
    radius: 16, speed: 60, hp: 3, damage: 10, color: '#4a7a3b',
    score: 100, bodyColor: '#3d6630'
  },
  fast: {
    radius: 13, speed: 130, hp: 2, damage: 8, color: '#8e44ad',
    score: 150, bodyColor: '#6c3483'
  },
  tank: {
    radius: 24, speed: 35, hp: 10, damage: 20, color: '#7f1d1d',
    score: 300, bodyColor: '#5a1414'
  },
  exploder: {
    radius: 18, speed: 50, hp: 4, damage: 15, color: '#d4ac0d',
    score: 200, bodyColor: '#b7950b'
  },
  boss: {
    radius: 35, speed: 40, hp: 50, damage: 25, color: '#ff0000',
    score: 1000, bodyColor: '#cc0000'
  },
  giant: {
    radius: 50, speed: 30, hp: 100, damage: 40, color: '#8b0000',
    score: 2000, bodyColor: '#660000'
  },
};

function spawnZombie() {
  let pool = ['normal'];
  if (wave >= 2) pool.push('normal', 'fast');
  if (wave >= 3) pool.push('fast', 'exploder');
  if (wave >= 4) pool.push('tank');
  if (wave >= 5) pool.push('fast', 'tank', 'exploder');
  if (wave >= 8 && Math.random() < 0.05) pool.push('boss');
  if (wave >= 10 && Math.random() < 0.08) pool.push('giant');

  const typeName = pool[Math.floor(Math.random() * pool.length)];
  const type = ZOMBIE_TYPES[typeName];

  let x, y;
  const side = Math.floor(Math.random() * 4);
  switch(side) {
    case 0: x = Math.random() * MAP_W; y = -30; break;
    case 1: x = MAP_W + 30; y = Math.random() * MAP_H; break;
    case 2: x = Math.random() * MAP_W; y = MAP_H + 30; break;
    case 3: x = -30; y = Math.random() * MAP_H; break;
  }

  const hpMult = 1 + (wave - 1) * 0.3;
  const damageMult = 1 + (wave - 1) * 0.2;

  zombies.push({
    x, y,
    radius: type.radius,
    speed: type.speed * (0.9 + Math.random() * 0.3),
    hp: Math.ceil(type.hp * hpMult),
    maxHp: Math.ceil(type.hp * hpMult),
    damage: Math.ceil(type.damage * damageMult),
    color: type.color,
    bodyColor: type.bodyColor,
    score: Math.ceil(type.score * (0.8 + wave * 0.2)),
    type: typeName,
    angle: 0,
    attackCooldown: 0,
    wobble: Math.random() * Math.PI * 2,
    specialAttackCooldown: 0,
  });
}

// ===================== 子弹 =====================
function fireBullet() {
  const weapon = WEAPONS[player.currentWeapon];
  const playerWeapon = player.weapons[player.currentWeapon];
  if (playerWeapon.ammo <= 0 || reloading) return;

  const angle = player.angle;
  const dmg = weapon.damage * player.attackPower;

  if (player.currentWeapon === 'grenade') {
    // 手雷发射
    bullets.push({
      x: player.x + Math.cos(angle) * 25,
      y: player.y + Math.sin(angle) * 25,
      dx: Math.cos(angle) * 300,
      dy: Math.sin(angle) * 300,
      radius: 5,
      damage: dmg,
      life: 2,
      type: 'grenade',
      bounces: 5,
    });
    for (let i = 0; i < 8; i++) {
      const a = Math.random() * Math.PI * 2;
      particles.push({
        x: player.x + Math.cos(angle) * 28,
        y: player.y + Math.sin(angle) * 28,
        dx: Math.cos(a) * (100 + Math.random() * 100),
        dy: Math.sin(a) * (100 + Math.random() * 100),
        life: 0.2,
        maxLife: 0.2,
        radius: 2 + Math.random() * 2,
        color: `hsl(40, 100%, 50%)`,
      });
    }
  } else if (player.currentWeapon === 'knife') {
    // 匕首近战
    const slashRadius = 40;
    zombies.forEach(z => {
      const dx = z.x - player.x;
      const dy = z.y - player.y;
      const dist = Math.hypot(dx, dy);
      if (dist < slashRadius && Math.abs(Math.atan2(dy, dx) - angle) < 0.8) {
        z.hp -= dmg;
        spawnBlood(z.x, z.y, 8, z.color);
        shotsHit++;
      }
    });
    // 刀光特效
    for (let i = 0; i < 15; i++) {
      const a = angle + (Math.random() - 0.5) * 1;
      particles.push({
        x: player.x + Math.cos(a) * 30,
        y: player.y + Math.sin(a) * 30,
        dx: Math.cos(a) * (150 + Math.random() * 100),
        dy: Math.sin(a) * (150 + Math.random() * 100),
        life: 0.15,
        maxLife: 0.15,
        radius: 3 + Math.random() * 3,
        color: '#ffdd00',
      });
    }
  } else {
    // 普通枪支发射
    const numBullets = player.currentWeapon === 'shotgun' ? 8 : 1;
    for (let n = 0; n < numBullets; n++) {
      const spread = (Math.random() - 0.5) * weapon.spread;
      bullets.push({
        x: player.x + Math.cos(angle) * 25,
        y: player.y + Math.sin(angle) * 25,
        dx: Math.cos(angle + spread) * 600,
        dy: Math.sin(angle + spread) * 600,
        radius: 3,
        damage: dmg,
        life: 1.5,
        type: 'bullet',
      });
    }

    // 枪口火焰粒子
    const particleCount = player.currentWeapon === 'shotgun' ? 15 : 5;
    for (let i = 0; i < particleCount; i++) {
      particles.push({
        x: player.x + Math.cos(angle) * 28,
        y: player.y + Math.sin(angle) * 28,
        dx: Math.cos(angle + (Math.random()-0.5)*0.5) * (150 + Math.random()*100),
        dy: Math.sin(angle + (Math.random()-0.5)*0.5) * (150 + Math.random()*100),
        life: 0.15,
        maxLife: 0.15,
        radius: 2 + Math.random() * 3,
        color: `hsl(${30 + Math.random()*20}, 100%, ${60 + Math.random()*30}%)`,
      });
    }
  }

  playerWeapon.ammo -= weapon.ammoPerShot;
  shotsFired++;
  playSound(800, 0.05, 'sine', 0.2);
}

function startReload() {
  const playerWeapon = player.weapons[player.currentWeapon];
  if (reloading || playerWeapon.ammo === playerWeapon.maxAmmo) return;
  reloading = true;
  reloadTimer = 1.5 / player.attackSpeed;
  playSound(400, 0.15, 'sine', 0.1);
}

// ===================== 音效系统 =====================
function playSound(freq, duration, type = 'sine', volume = 0.3) {
  try {
    if (!audioContext) {
      audioContext = new (window.AudioContext || window.webkitAudioContext)();
    }
    const osc = audioContext.createOscillator();
    const gain = audioContext.createGain();
    osc.connect(gain);
    gain.connect(audioContext.destination);
    osc.type = type;
    osc.frequency.value = freq;
    gain.gain.setValueAtTime(volume, audioContext.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + duration);
    osc.start(audioContext.currentTime);
    osc.stop(audioContext.currentTime + duration);
  } catch(e) {}
}

// ===================== 成就系统 =====================
function triggerAchievement(title, desc, score) {
  const container = document.body;
  const ach = document.createElement('div');
  ach.className = 'achievement';
  ach.innerHTML = `<div class="achievement-title">🏆 ${title}</div><div class="achievement-desc">${desc}</div>`;
  container.appendChild(ach);
  score += score;
  setTimeout(() => ach.remove(), 4000);
}

function showKillStreak(num) {
  if (num > 1) {
    const ks = document.getElementById('killstreakHUD');
    ks.textContent = `🔥 ${num} 连杀!`;
    ks.classList.remove('active');
    void ks.offsetWidth; // 重排触发
    ks.classList.add('active');
    if (num === 5) triggerAchievement('5连杀', '无敌！', 50);
    if (num === 10) triggerAchievement('10连杀', '神级玩家！', 100);
    if (num === 20) triggerAchievement('20连杀', '传奇猎手！', 200);
    playSound(600 + num * 50, 0.2, 'triangle', 0.4);
  }
}

// ===================== 粒子 & 特效 =====================
function spawnBlood(x, y, amount, color = '#8b0000') {
  for (let i = 0; i < amount; i++) {
    const angle = Math.random() * Math.PI * 2;
    const speed = 50 + Math.random() * 150;
    particles.push({
      x, y,
      dx: Math.cos(angle) * speed,
      dy: Math.sin(angle) * speed,
      life: 0.3 + Math.random() * 0.5,
      maxLife: 0.8,
      radius: 2 + Math.random() * 4,
      color: color,
      gravity: 200,
    });
  }
  // 地面血迹
  bloodSplats.push({
    x, y,
    radius: 8 + Math.random() * 15,
    alpha: 0.6,
  });
}

// 飘动得分数字
function spawnFloatingText(x, y, text, color = '#ffff00') {
  floatingTexts.push({
    x, y,
    text,
    color,
    life: 1.5,
    maxLife: 1.5,
  });
}

function spawnExplosion(x, y, baseDamage = 10) {
  for (let i = 0; i < 30; i++) {
    const angle = Math.random() * Math.PI * 2;
    const speed = 100 + Math.random() * 250;
    particles.push({
      x, y,
      dx: Math.cos(angle) * speed,
      dy: Math.sin(angle) * speed,
      life: 0.3 + Math.random() * 0.4,
      maxLife: 0.7,
      radius: 3 + Math.random() * 5,
      color: `hsl(${Math.random()*40 + 10}, 100%, 50%)`,
    });
  }
  // 范围伤害
  zombies.forEach(z => {
    const dist = Math.hypot(z.x - x, z.y - y);
    if (dist < 120) {
      z.hp -= baseDamage * (1 - dist / 120);
      spawnBlood(z.x, z.y, 5, z.color);
    }
  });
  // 伤害玩家
  const pd = Math.hypot(player.x - x, player.y - y);
  if (pd < 120 && player.invincible <= 0) {
    player.hp -= Math.max(5, 30 - pd / 4);
  }
}

function spawnPickup(x, y) {
  const rand = Math.random();
  if (rand < 0.4) {
    const types = ['health', 'ammo', 'coin', 'coin'];
    const type = types[Math.floor(Math.random() * types.length)];
    const value = type === 'coin' ? (5 + wave * 2) : (type === 'health' ? 0 : 0);
    pickups.push({
      x, y,
      type,
      radius: 12,
      life: 10,
      bob: Math.random() * Math.PI * 2,
      value,
    });
  }
}

// ===================== 波次系统 =====================
function startWave() {
  wave++;
  zombiesLeft = 5 + wave * 4;
  waveDelay = 0;

  const announce = document.getElementById('waveAnnounce');
  announce.textContent = `⚔️ 第 ${wave} 波`;
  announce.classList.add('show');
  setTimeout(() => announce.classList.remove('show'), 2500);

  document.getElementById('hudWave').textContent = wave;
}

// ===================== 主要游戏逻辑 =====================
function update(dt) {
  if (!gameRunning || gamePaused) return;

  // -- 玩家移动 --
  let mx = 0, my = 0;
  if (keys['w'] || keys['arrowup']) my -= 1;
  if (keys['s'] || keys['arrowdown']) my += 1;
  if (keys['a'] || keys['arrowleft']) mx -= 1;
  if (keys['d'] || keys['arrowright']) mx += 1;

  if (mx !== 0 || my !== 0) {
    const len = Math.hypot(mx, my);
    mx /= len; my /= len;
  }

  // 翻滚
  if (player.dashTimer > 0) {
    player.dashTimer -= dt;
    player.x += player.dashDx * dt;
    player.y += player.dashDy * dt;
    player.invincible = 0.1;
  } else {
    player.x += mx * player.speed * dt;
    player.y += my * player.speed * dt;
  }

  // 边界
  player.x = Math.max(player.radius, Math.min(MAP_W - player.radius, player.x));
  player.y = Math.max(player.radius, Math.min(MAP_H - player.radius, player.y));

  // 鼠标角度
  const worldMouseX = mouse.x + camera.x;
  const worldMouseY = mouse.y + camera.y;
  player.angle = Math.atan2(worldMouseY - player.y, worldMouseX - player.x);

  // 无敌时间
  if (player.invincible > 0) player.invincible -= dt;

  // 翻滚冷却
  if (dashCooldown > 0) dashCooldown -= dt;

  // 射击
  shootCooldown -= dt;
  if (mouse.down && shootCooldown <= 0 && !reloading && player.weapons[player.currentWeapon].ammo > 0) {
    fireBullet();
    const weapon = WEAPONS[player.currentWeapon];
    shootCooldown = weapon.fireRate / player.attackSpeed;
  }

  // 换弹
  if (reloading) {
    reloadTimer -= dt;
    if (reloadTimer <= 0) {
      player.weapons[player.currentWeapon].ammo = player.weapons[player.currentWeapon].maxAmmo;
      reloading = false;
    }
  }
  const playerWeapon = player.weapons[player.currentWeapon];
  if (playerWeapon.ammo <= 0 && !reloading && player.currentWeapon !== 'knife') startReload();

  // -- 子弹更新 --
  bullets.forEach((b, idx) => {
    b.x += b.dx * dt;
    b.y += b.dy * dt;
    b.life -= dt;
    
    if (b.type === 'grenade') {
      b.dy += 300 * dt; // 重力
      if ((b.x < 0 || b.x > MAP_W || b.y < 0 || b.y > MAP_H) && b.bounces > 0) {
        b.bounces--;
        if (b.x < 0 || b.x > MAP_W) b.dx *= -0.5;
        if (b.y < 0 || b.y > MAP_H) b.dy *= -0.5;
        b.x = Math.max(0, Math.min(MAP_W, b.x));
        b.y = Math.max(0, Math.min(MAP_H, b.y));
      }
    }
  });
  
  // 手雷爆炸处理
  bullets.forEach((b, idx) => {
    if (b.type === 'grenade' && (b.life <= 0 || b.bounces <= 0)) {
      spawnExplosion(b.x, b.y, b.damage);
      bullets.splice(idx, 1);
    }
  });
  
  bullets = bullets.filter(b => b.life > 0 && b.x > -50 && b.x < MAP_W+50 && b.y > -50 && b.y < MAP_H+50);

  // -- 僵尸更新 --
  zombies.forEach(z => {
    const dx = player.x - z.x;
    const dy = player.y - z.y;
    const dist = Math.hypot(dx, dy);
    z.angle = Math.atan2(dy, dx);

    z.wobble += dt * 5;

    if (dist > z.radius + player.radius) {
      const wobbleX = Math.sin(z.wobble) * 0.3;
      z.x += (Math.cos(z.angle) + wobbleX) * z.speed * dt;
      z.y += (Math.sin(z.angle)) * z.speed * dt;
    }

    // 攻击玩家
    z.attackCooldown -= dt;
    if (dist < z.radius + player.radius + 5 && z.attackCooldown <= 0 && player.invincible <= 0) {
      player.hp -= z.damage;
      player.invincible = 0.3;
      z.attackCooldown = 1;
      spawnBlood(player.x, player.y, 8, '#cc0000');

      // 击退
      const kb = 80;
      player.x -= Math.cos(z.angle) * kb * dt * 10;
      player.y -= Math.sin(z.angle) * kb * dt * 10;
    }

    // 僵尸之间碰撞
    zombies.forEach(z2 => {
      if (z === z2) return;
      const d = Math.hypot(z.x - z2.x, z.y - z2.y);
      const minD = z.radius + z2.radius;
      if (d < minD && d > 0) {
        const overlap = (minD - d) / 2;
        const ax = (z.x - z2.x) / d;
        const ay = (z.y - z2.y) / d;
        z.x += ax * overlap;
        z.y += ay * overlap;
        z2.x -= ax * overlap;
        z2.y -= ay * overlap;
      }
    });
  });

  // -- 子弹碰撞 --
  bullets.forEach(b => {
    zombies.forEach(z => {
      if ((b.type !== 'grenade' && b.life <= 0) || z.hp <= 0) return;
      const dist = Math.hypot(b.x - z.x, b.y - z.y);
      if (dist < b.radius + z.radius) {
        z.hp -= b.damage;
        b.life = 0;
        shotsHit++;
        spawnBlood(b.x, b.y, 6, z.color);

        // 击退
        const angle = Math.atan2(b.dy, b.dx);
        z.x += Math.cos(angle) * 8;
        z.y += Math.sin(angle) * 8;
      }
    });
  });

  // -- 死亡僵尸 --
  zombies = zombies.filter(z => {
    if (z.hp <= 0) {
      kills++;
      killstreakCounter++;
      lastKillTime = Date.now();
      score += z.score;
      const coinReward = Math.ceil(z.score / 10);
      coins += coinReward;
      spawnBlood(z.x, z.y, 15, z.color);
      spawnFloatingText(z.x, z.y, `+${z.score}`, '#ffff00');
      spawnFloatingText(z.x, z.y - 20, `$${coinReward}`, '#ffd700');
      spawnPickup(z.x, z.y);
      
      // BOSS击杀
      if (z.type === 'boss' || z.type === 'giant') {
        playSound(200, 0.5, 'sine', 0.5);
        triggerAchievement(`${z.type === 'giant' ? '巨人' : 'BOSS'}击杀！`, `+${z.score}分`, z.score);
        spawnFloatingText(z.x, z.y - 40, z.type === 'giant' ? '巨人已消灭!' : 'BOSS已消灭!', '#ff6600');
        // 爆炸特效
        for(let i = 0; i < 60; i++) {
          const angle = Math.random() * Math.PI * 2;
          const speed = 150 + Math.random() * 300;
          particles.push({
            x: z.x, y: z.y,
            dx: Math.cos(angle) * speed,
            dy: Math.sin(angle) * speed,
            life: 0.4 + Math.random() * 0.3,
            maxLife: 0.7,
            radius: 4 + Math.random() * 6,
            color: `hsl(${Math.random()*360}, 100%, 50%)`,
          });
        }
      }
      
      if (z.type === 'exploder') spawnExplosion(z.x, z.y, 10);
      showKillStreak(killstreakCounter);
      return false;
    }
    return true;
  });

  // -- 拾取物 --
  pickups.forEach(p => {
    p.life -= dt;
    p.bob += dt * 3;
    const dist = Math.hypot(p.x - player.x, p.y - player.y);
    if (dist < p.radius + player.radius + 10) {
      if (p.type === 'health') {
        player.hp = Math.min(player.maxHp, player.hp + 25);
        playSound(500, 0.2, 'sine', 0.3);
      } else if (p.type === 'ammo') {
        player.weapons[player.currentWeapon].ammo = player.weapons[player.currentWeapon].maxAmmo;
        reloading = false;
        playSound(700, 0.15, 'sine', 0.3);
      } else if (p.type === 'coin') {
        coins += p.value;
        spawnFloatingText(p.x, p.y, `+$${p.value}`, '#ffd700');
        playSound(800, 0.1, 'sine', 0.3);
      }
      p.life = 0;
    }
  });
  pickups = pickups.filter(p => p.life > 0);

  // -- 粒子 --
  particles.forEach(p => {
    p.x += p.dx * dt;
    p.y += p.dy * dt;
    if (p.gravity) p.dy += p.gravity * dt;
    p.dx *= 0.95;
    p.dy *= 0.95;
    p.life -= dt;
  });
  particles = particles.filter(p => p.life > 0);

  // -- 飘动数字 --
  floatingTexts.forEach(t => {
    t.y -= 100 * dt;
    t.life -= dt;
  });
  floatingTexts = floatingTexts.filter(t => t.life > 0);

  // -- 血迹淡出 --
  bloodSplats.forEach(b => b.alpha -= dt * 0.03);
  bloodSplats = bloodSplats.filter(b => b.alpha > 0);
  if (bloodSplats.length > 200) bloodSplats.splice(0, 50);

  // -- 波次管理 --
  if (zombiesLeft > 0) {
    waveDelay -= dt;
    if (waveDelay <= 0) {
      spawnZombie();
      zombiesLeft--;
      waveDelay = Math.max(0.3, 2 - wave * 0.15);
    }
  } else if (zombies.length === 0) {
    killstreakCounter = 0;
    startWave();
  }

  // 连杀重置
  if (Date.now() - lastKillTime > 3000) {
    killstreakCounter = 0;
  }

  // -- 相机 --
  camera.x = player.x - W / 2;
  camera.y = player.y - H / 2;
  camera.x = Math.max(0, Math.min(MAP_W - W, camera.x));
  camera.y = Math.max(0, Math.min(MAP_H - H, camera.y));

  // -- UI --
  document.getElementById('healthBar').style.width = Math.max(0, player.hp / player.maxHp * 100) + '%';
  document.getElementById('healthBar').style.background =
    player.hp > 60 ? 'linear-gradient(90deg, #27ae60, #2ecc71)' :
    player.hp > 30 ? 'linear-gradient(90deg, #f39c12, #e67e22)' :
    'linear-gradient(90deg, #e74c3c, #c0392b)';
  document.getElementById('hudScore').textContent = score;
  document.getElementById('hudKills').textContent = kills;
  document.getElementById('hudCoins').textContent = coins;
  const currentWeaponData = WEAPONS[player.currentWeapon];
  document.getElementById('hudWeapon').textContent = currentWeaponData.emoji + ' ' + currentWeaponData.name;
  const currentWpn = player.weapons[player.currentWeapon];
  document.getElementById('hudAmmo').textContent = reloading ? '装填中...' : (currentWpn.ammo === 999 ? '∞' : currentWpn.ammo);

  // -- 死亡检查 --
  if (player.hp <= 0) {
    endGame();
  }
}

// ===================== 渲染 =====================
function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.save();
  ctx.translate(-camera.x, -camera.y);

  // -- 地面 --
  drawGround();

  // -- 血迹 --
  bloodSplats.forEach(b => {
    ctx.globalAlpha = b.alpha;
    ctx.fillStyle = '#4a0e0e';
    ctx.beginPath();
    ctx.arc(b.x, b.y, b.radius, 0, Math.PI * 2);
    ctx.fill();
  });
  ctx.globalAlpha = 1;

  // -- 拾取物 --
  pickups.forEach(p => {
    const bobY = Math.sin(p.bob) * 4;
    ctx.save();
    ctx.translate(p.x, p.y + bobY);

    // 光晕
    ctx.globalAlpha = 0.3 + Math.sin(p.bob) * 0.1;
    ctx.fillStyle = p.type === 'health' ? '#2ecc71' : '#f39c12';
    ctx.beginPath();
    ctx.arc(0, 0, 18, 0, Math.PI * 2);
    ctx.fill();

    ctx.globalAlpha = 1;
    ctx.font = '20px Arial';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(p.type === 'health' ? '❤️' : '🔫', 0, 0);
    ctx.restore();
  });

  // -- 僵尸 --
  zombies.forEach(drawZombie);

  // -- 子弹 --
  bullets.forEach(b => {
    ctx.fillStyle = '#ffdd57';
    ctx.shadowColor = '#ff6600';
    ctx.shadowBlur = 8;
    ctx.beginPath();
    ctx.arc(b.x, b.y, b.radius, 0, Math.PI * 2);
    ctx.fill();
    ctx.shadowBlur = 0;

    // 弹道尾迹
    ctx.strokeStyle = 'rgba(255,200,50,0.4)';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(b.x, b.y);
    ctx.lineTo(b.x - b.dx * 0.02, b.y - b.dy * 0.02);
    ctx.stroke();
  });

  // -- 粒子 --
  particles.forEach(p => {
    ctx.globalAlpha = Math.max(0, p.life / p.maxLife);
    ctx.fillStyle = p.color;
    ctx.beginPath();
    ctx.arc(p.x, p.y, p.radius * (p.life / p.maxLife), 0, Math.PI * 2);
    ctx.fill();
  });
  ctx.globalAlpha = 1;

  // -- 飘动数字 --
  floatingTexts.forEach(t => {
    ctx.globalAlpha = Math.max(0, t.life / t.maxLife);
    ctx.fillStyle = t.color;
    ctx.font = 'bold 20px Arial';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.shadowColor = 'rgba(0,0,0,0.5)';
    ctx.shadowBlur = 4;
    ctx.fillText(t.text, t.x, t.y);
    ctx.shadowBlur = 0;
  });
  ctx.globalAlpha = 1;

  // -- 玩家 --
  drawPlayer();

  // -- 地图边界 --
  ctx.strokeStyle = '#e74c3c';
  ctx.lineWidth = 3;
  ctx.shadowColor = '#e74c3c';
  ctx.shadowBlur = 15;
  ctx.strokeRect(0, 0, MAP_W, MAP_H);
  ctx.shadowBlur = 0;

  ctx.restore();

  // -- 准星 --
  drawCrosshair();

  // -- 小地图 --
  drawMinimap();

  // -- 换弹进度 --
  if (reloading) {
    const progress = 1 - reloadTimer / 1.5;
    const cx = W / 2, cy = H / 2 + 50;
    ctx.strokeStyle = '#555';
    ctx.lineWidth = 4;
    ctx.beginPath();
    ctx.arc(cx, cy, 20, 0, Math.PI * 2);
    ctx.stroke();
    ctx.strokeStyle = '#f39c12';
    ctx.lineWidth = 4;
    ctx.beginPath();
    ctx.arc(cx, cy, 20, -Math.PI/2, -Math.PI/2 + Math.PI * 2 * progress);
    ctx.stroke();
    ctx.fillStyle = '#fff';
    ctx.font = '10px Arial';
    ctx.textAlign = 'center';
    ctx.fillText('装填', cx, cy + 4);
  }
}

function drawGround() {
  // 地面颜色
  ctx.fillStyle = '#1a2a1a';
  ctx.fillRect(0, 0, MAP_W, MAP_H);

  // 网格
  ctx.strokeStyle = 'rgba(255,255,255,0.04)';
  ctx.lineWidth = 1;
  const gridSize = 60;
  const startX = Math.floor(camera.x / gridSize) * gridSize;
  const startY = Math.floor(camera.y / gridSize) * gridSize;
  for (let x = startX; x < camera.x + W + gridSize; x += gridSize) {
    ctx.beginPath();
    ctx.moveTo(x, camera.y);
    ctx.lineTo(x, camera.y + H);
    ctx.stroke();
  }
  for (let y = startY; y < camera.y + H + gridSize; y += gridSize) {
    ctx.beginPath();
    ctx.moveTo(camera.x, y);
    ctx.lineTo(camera.x + W, y);
    ctx.stroke();
  }
}

function drawPlayer() {
  const p = player;
  ctx.save();
  ctx.translate(p.x, p.y);

  // 受伤闪烁
  if (p.invincible > 0 && Math.floor(p.invincible * 20) % 2) {
    ctx.globalAlpha = 0.5;
  }

  // 翻滚特效
  if (p.dashTimer > 0) {
    ctx.globalAlpha = 0.6;
  }

  // 身体（阴影）
  ctx.fillStyle = 'rgba(0,0,0,0.3)';
  ctx.beginPath();
  ctx.arc(3, 3, p.radius, 0, Math.PI * 2);
  ctx.fill();

  // 身体
  ctx.fillStyle = '#3498db';
  ctx.strokeStyle = '#2980b9';
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.arc(0, 0, p.radius, 0, Math.PI * 2);
  ctx.fill();
  ctx.stroke();

  // 身体高光
  ctx.fillStyle = 'rgba(255,255,255,0.15)';
  ctx.beginPath();
  ctx.arc(-3, -5, p.radius * 0.5, 0, Math.PI * 2);
  ctx.fill();

  // 枪
  ctx.rotate(p.angle);
  ctx.fillStyle = '#7f8c8d';
  ctx.fillRect(10, -3, 20, 6);
  ctx.fillStyle = '#95a5a6';
  ctx.fillRect(12, -2, 16, 2);

  ctx.restore();
  ctx.globalAlpha = 1;
}

function drawZombie(z) {
  ctx.save();
  ctx.translate(z.x, z.y);

  // 阴影
  ctx.fillStyle = 'rgba(0,0,0,0.3)';
  ctx.beginPath();
  ctx.ellipse(3, 3, z.radius, z.radius * 0.8, 0, 0, Math.PI * 2);
  ctx.fill();

  // 身体
  ctx.rotate(z.angle);
  ctx.fillStyle = z.bodyColor;
  ctx.strokeStyle = 'rgba(0,0,0,0.3)';
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.arc(0, 0, z.radius, 0, Math.PI * 2);
  ctx.fill();
  ctx.stroke();

  // 身体纹理
  ctx.fillStyle = z.color;
  ctx.beginPath();
  ctx.arc(-2, -2, z.radius * 0.7, 0, Math.PI * 2);
  ctx.fill();

  // BOSS特殊效果
  if (z.type === 'boss' || z.type === 'giant') {
    ctx.strokeStyle = z.type === 'giant' ? 'rgba(150, 50, 50, 0.8)' : 'rgba(255, 100, 100, 0.8)';
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.arc(0, 0, z.radius + 5, 0, Math.PI * 2);
    ctx.stroke();
    ctx.globalAlpha = 0.4;
    ctx.strokeStyle = z.type === 'giant' ? 'rgba(100, 30, 30, 0.6)' : 'rgba(255, 50, 50, 0.6)';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.arc(0, 0, z.radius + 10, 0, Math.PI * 2);
    ctx.stroke();
    ctx.globalAlpha = 1;
  }

  // 手臂
  const armWobble = Math.sin(z.wobble) * 0.3;
  ctx.fillStyle = z.color;
  ctx.save();
  ctx.rotate(armWobble + 0.4);
  ctx.fillRect(z.radius - 4, -12, 14, 6);
  ctx.restore();
  ctx.save();
  ctx.rotate(-armWobble - 0.4);
  ctx.fillRect(z.radius - 4, 6, 14, 6);
  ctx.restore();

  // 眼睛
  ctx.fillStyle = z.type === 'boss' || z.type === 'giant' ? '#ffff00' : (z.type === 'exploder' ? '#ff0' : '#ff3333');
  ctx.shadowColor = z.type === 'boss' || z.type === 'giant' ? '#ffff00' : (z.type === 'exploder' ? '#ff0' : '#ff0000');
  ctx.shadowBlur = z.type === 'boss' || z.type === 'giant' ? 12 : 6;
  ctx.beginPath();
  ctx.arc(z.radius * 0.35, -4, z.type === 'boss' || z.type === 'giant' ? 5 : 3, 0, Math.PI * 2);
  ctx.fill();
  ctx.beginPath();
  ctx.arc(z.radius * 0.35, 4, z.type === 'boss' || z.type === 'giant' ? 5 : 3, 0, Math.PI * 2);
  ctx.fill();
  ctx.shadowBlur = 0;

  ctx.rotate(-z.angle);

  // 血条
  if (z.hp < z.maxHp || z.type === 'boss' || z.type === 'giant') {
    const bw = z.radius * 2;
    ctx.fillStyle = 'rgba(0,0,0,0.5)';
    ctx.fillRect(-bw/2, -z.radius - 10, bw, 4);
    ctx.fillStyle = z.type === 'boss' || z.type === 'giant' ? '#ff6600' : (z.hp / z.maxHp > 0.5 ? '#2ecc71' : '#e74c3c');
    ctx.fillRect(-bw/2, -z.radius - 10, bw * (z.hp / z.maxHp), 4);
    
    // BOSS/GIANT显示名称
    if (z.type === 'boss' || z.type === 'giant') {
      ctx.fillStyle = '#ffff00';
      ctx.font = 'bold 14px Arial';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.shadowColor = z.type === 'giant' ? '#cc6600' : '#ff0000';
      ctx.shadowBlur = 8;
      ctx.fillText(z.type === 'giant' ? '👹 巨人 👹' : '👑 BOSS 👑', 0, -z.radius - 25);
      ctx.shadowBlur = 0;
    }
  }

  ctx.restore();
  ctx.globalAlpha = 1;
}

function drawCrosshair() {
  const cx = mouse.x, cy = mouse.y;
  ctx.strokeStyle = 'rgba(255,50,50,0.8)';
  ctx.lineWidth = 2;

  ctx.beginPath();
  ctx.arc(cx, cy, 15, 0, Math.PI * 2);
  ctx.stroke();

  const gap = 8, len = 6;
  ctx.beginPath();
  ctx.moveTo(cx - gap - len, cy); ctx.lineTo(cx - gap, cy);
  ctx.moveTo(cx + gap, cy); ctx.lineTo(cx + gap + len, cy);
  ctx.moveTo(cx, cy - gap - len); ctx.lineTo(cx, cy - gap);
  ctx.moveTo(cx, cy + gap); ctx.lineTo(cx, cy + gap + len);
  ctx.stroke();

  ctx.fillStyle = '#ff3333';
  ctx.beginPath();
  ctx.arc(cx, cy, 2, 0, Math.PI * 2);
  ctx.fill();
}

function drawMinimap() {
  const mw = 150, mh = 112;
  const mx = W - mw - 15, my = H - mh - 15;
  const sx = mw / MAP_W, sy = mh / MAP_H;

  ctx.fillStyle = 'rgba(0,0,0,0.6)';
  ctx.strokeStyle = 'rgba(255,255,255,0.2)';
  ctx.lineWidth = 1;
  ctx.fillRect(mx, my, mw, mh);
  ctx.strokeRect(mx, my, mw, mh);

  // 视野框
  ctx.strokeStyle = 'rgba(255,255,255,0.3)';
  ctx.strokeRect(mx + camera.x * sx, my + camera.y * sy, W * sx, H * sy);

  // 僵尸点
  ctx.fillStyle = '#e74c3c';
  zombies.forEach(z => {
    ctx.fillRect(mx + z.x * sx - 1, my + z.y * sy - 1, 3, 3);
  });

  // 拾取物
  ctx.fillStyle = '#2ecc71';
  pickups.forEach(p => {
    ctx.fillRect(mx + p.x * sx - 1, my + p.y * sy - 1, 3, 3);
  });

  // 玩家
  ctx.fillStyle = '#3498db';
  ctx.beginPath();
  ctx.arc(mx + player.x * sx, my + player.y * sy, 3, 0, Math.PI * 2);
  ctx.fill();
}

// ===================== 游戏循环 =====================
function gameLoop(timestamp) {
  const dt = Math.min((timestamp - lastTime) / 1000, 0.05);
  lastTime = timestamp;

  update(dt);
  draw();

  if (gameRunning) requestAnimationFrame(gameLoop);
}

// ===================== 游戏控制 =====================
function startGame() {
  player = createPlayer();
  zombies = [];
  bullets = [];
  particles = [];
  pickups = [];
  bloodSplats = [];
  floatingTexts = [];
  score = 0;
  kills = 0;
  wave = 0;
  zombiesLeft = 0;
  waveDelay = 0;
  shotsFired = 0;
  shotsHit = 0;
  reloading = false;
  shootCooldown = 0;
  dashCooldown = 0;
  gamePaused = false;
  shopOpen = false;
  gameRunning = true;
  killstreakCounter = 0;

  // 重置武器拥有状态，只有手枪初始拥有
  Object.keys(WEAPONS).forEach(key => {
    WEAPONS[key].owned = (key === 'pistol');
  });

  document.getElementById('startScreen').classList.add('hidden');
  document.getElementById('gameOverScreen').classList.add('hidden');
  document.getElementById('hud').classList.remove('hidden');
  document.getElementById('pauseBtn').style.display = 'block';
  document.getElementById('shopBtn').style.display = 'block';
  document.getElementById('pauseMenu').classList.remove('active');
  document.getElementById('shopMenu').classList.remove('active');

  startWave();
  lastTime = performance.now();
  requestAnimationFrame(gameLoop);
}

function togglePause() {
  if (!gameRunning) return;
  gamePaused = !gamePaused;
  const menu = document.getElementById('pauseMenu');
  if (gamePaused) {
    menu.classList.add('active');
    document.getElementById('pauseScore').textContent = score;
    document.getElementById('pauseKills').textContent = kills;
    document.getElementById('pauseWave').textContent = wave;
  } else {
    menu.classList.remove('active');
  }
}

function toggleShop() {
  if (!gameRunning) return;
  shopOpen = !shopOpen;
  const shop = document.getElementById('shopMenu');
  if (shopOpen) {
    shop.classList.add('active');
    updateShopDisplay();
    gamePaused = true;
  } else {
    shop.classList.remove('active');
    gamePaused = false;
  }
}

function updateShopDisplay() {
  document.getElementById('shopCoins').textContent = coins;
  const shopItems = document.getElementById('shopItems');
  shopItems.innerHTML = '';
  
  Object.entries(WEAPONS).forEach(([key, weapon]) => {
    if (key === player.currentWeapon) return; // 不显示已装备的武器
    
    const item = document.createElement('div');
    item.className = 'shop-item' + (WEAPONS[key].owned ? ' owned' : '');
    const stats = `伤害: ${weapon.damage} | 射速: ${(1/weapon.fireRate).toFixed(1)} | 弹容: ${weapon.ammo}`;
    const costText = WEAPONS[key].owned ? '已拥有 (点击切换)' : `购买 - $${weapon.cost}`;
    item.innerHTML = `
      <div class="shop-item-name">${weapon.emoji} ${weapon.name}</div>
      <div class="shop-item-stats">${stats}</div>
      <div class="shop-item-cost">${costText}</div>
    `;
    item.onclick = () => buyWeapon(key);
    shopItems.appendChild(item);
  });
}

function buyWeapon(weaponKey) {
  const weapon = WEAPONS[weaponKey];
  if (weapon.owned) {
    // 切换武器
    player.currentWeapon = weaponKey;
    reloading = false;
    updateShopDisplay();
    playSound(600, 0.2, 'sine', 0.3);
  } else if (coins >= weapon.cost) {
    // 购买武器
    coins -= weapon.cost;
    WEAPONS[weaponKey].owned = true;
    player.weapons[weaponKey].ammo = weapon.ammo;
    player.currentWeapon = weaponKey;
    reloading = false;
    triggerAchievement('新武器解锁！', `获得${weapon.name}`, weapon.cost);
    updateShopDisplay();
    playSound(900, 0.3, 'sine', 0.4);
  } else {
    triggerAchievement('金币不足', `需要 $${weapon.cost - coins} 更多金币`, 0);
    playSound(200, 0.3, 'sine', 0.2);
  }
}

function endGame() {
  gameRunning = false;
  document.getElementById('hud').classList.add('hidden');
  document.getElementById('pauseBtn').style.display = 'none';
  document.getElementById('shopBtn').style.display = 'none';
  document.getElementById('pauseMenu').classList.remove('active');
  document.getElementById('shopMenu').classList.remove('active');
  document.getElementById('gameOverScreen').classList.remove('hidden');
  document.getElementById('goScore').textContent = '最终得分: ' + score;
  document.getElementById('goKills').textContent = kills;
  document.getElementById('goWave').textContent = wave;
  document.getElementById('goAccuracy').textContent =
    shotsFired > 0 ? Math.round(shotsHit / shotsFired * 100) + '%' : '0%';
}

// ===================== 输入处理 =====================
document.addEventListener('keydown', e => {
  keys[e.key.toLowerCase()] = true;
  if (e.key.toLowerCase() === 'r' && gameRunning && !shopOpen) startReload();
  if (e.key.toLowerCase() === 'p' && gameRunning) togglePause();
  if (e.key.toLowerCase() === 'b' && gameRunning) toggleShop();
  // 数字键切换武器
  const num = parseInt(e.key);
  if (num >= 1 && num <= 6 && gameRunning && !shopOpen) {
    const weaponKeys = Object.keys(WEAPONS);
    if (num <= weaponKeys.length && WEAPONS[weaponKeys[num-1]].owned) {
      player.currentWeapon = weaponKeys[num-1];
      reloading = false;
    }
  }
  if (e.key === ' ' && gameRunning && !gamePaused && !shopOpen) {
    e.preventDefault();
    // 翻滚
    if (dashCooldown <= 0) {
      let dx = 0, dy = 0;
      if (keys['w'] || keys['arrowup']) dy = -1;
      if (keys['s'] || keys['arrowdown']) dy = 1;
      if (keys['a'] || keys['arrowleft']) dx = -1;
      if (keys['d'] || keys['arrowright']) dx = 1;
      if (dx === 0 && dy === 0) {
        dx = Math.cos(player.angle);
        dy = Math.sin(player.angle);
      }
      const len = Math.hypot(dx, dy);
      player.dashDx = (dx / len) * 500;
      player.dashDy = (dy / len) * 500;
      player.dashTimer = 0.2;
      dashCooldown = 1;
    }
  }
});

document.addEventListener('keyup', e => {
  keys[e.key.toLowerCase()] = false;
});

canvas.addEventListener('mousemove', e => {
  mouse.x = e.clientX;
  mouse.y = e.clientY;
});

canvas.addEventListener('mousedown', e => {
  if (e.button === 0) mouse.down = true;
});

canvas.addEventListener('mouseup', e => {
  if (e.button === 0) mouse.down = false;
});

canvas.addEventListener('contextmenu', e => e.preventDefault());

// 初始渲染
ctx.fillStyle = '#1a2a1a';
ctx.fillRect(0, 0, W, H);
</script>
